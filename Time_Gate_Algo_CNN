def integrate_with_existing_code(stack, quality_masks, temporal_decay=0.15):
    """
    Example showing how to replace your existing timegate_with_fmask function.
    
    Args:
        stack: (T, C, H, W) - your image stack
        quality_masks: (T, H, W) - your Fmask quality masks
        temporal_decay: float - decay parameter
    
    Returns:
        composite: (C, H, W) - cloud-free composite
        avg_weights: (T, H, W) - average weights per timestep
    """
    T, C, H, W = stack.shape
    
    # Prepare cloud masks (2 channels: cloud + shadow)
    # Using same mask for both channels (you can separate if you have both)
    cloud_masks = np.stack([quality_masks, quality_masks], axis=1)
    
    # Missing masks (same as quality masks in your case)
    missing_masks = quality_masks
    
    # Run TimeGate
    composite, H_agg, weights = run_timegate(
        stack, 
        cloud_masks, 
        missing_masks, 
        temporal_decay=temporal_decay,
        return_weights=True
    )
    
    # Average weights across channels for visualization
    avg_weights = np.mean(weights, axis=1)
    
    return composite, avg_weights


